{
  "expo": {
    "name": "NatsumeWatch",
    "slug": "natsumewatch",
    "scheme": "natsumewatch",
    "version": "1.0.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0a0613",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0613"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.natsumewatch.app"
    },
    "android": {
      "package": "com.natsumewatch.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0613"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-video",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Чтобы загрузить аватар или баннер, разрешите доступ к фото."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://natsumewatch-backend-wsjmfcnv.fly.dev",
      "eas": {
        "projectId": "b93ec29f-acfb-4fa6-997a-d6be6511a9b4"
      }
    },
    "owner": "natsumestun"
  }
}
